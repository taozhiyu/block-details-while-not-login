#: plugin.php
msgid "Settings saved."
msgstr "设置已保存。"

#: plugin.php
msgid "Settings reset to defaults."
msgstr "已恢复默认设置。"

#. translators: %1$s/%2$s wrap inline code (<code></code>); %3$s/%4$s wrap a link to YOURLS PR #2747.
#: plugin.php
msgid "Tip: also rename the %1$s/admin/%2$s directory and create a %1$suser/cache.php%2$s filter to mask the admin URL — see %3$sYOURLS PR #2747%4$s."
msgstr "建议：同时重命名 %1$s/admin/%2$s 目录并创建 %1$suser/cache.php%2$s 过滤器以掩盖后台地址——参见 %3$sYOURLS PR #2747%4$s。"
